# ─────────────────────────────────────────────────────────────
# Shortly — environment configuration
# Copy this file to `.env` and adjust the values for your setup.
# NEVER commit your real `.env` file (it is git-ignored).
# ─────────────────────────────────────────────────────────────

# Public base URL of the deployment. Used to build short links
# that are returned to the client (e.g. https://sho.rt).
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ── Storage backend ───────────────────────────────────────────
# By default Shortly uses a local JSON file store at `.data/store.json`.
# This is great for local development and single-instance self-hosting.
#
# For serverless / multi-instance deployments (Vercel, Fly, K8s) set BOTH
# of the following Upstash Redis credentials. When they are present,
# Shortly automatically switches to the Redis-backed store.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Short code generation ─────────────────────────────────────
# Length of generated short codes (characters). 6 is plenty (56^6 ≈ 20B).
SHORT_CODE_LENGTH=6

# Use a readable alphabet that avoids ambiguous characters (0/O, 1/l/I).
# Leave empty to use the default: 23456789abcdefghijkmnpqrstuvwxyz
SHORT_CODE_ALPHABET=

# ── Security ──────────────────────────────────────────────────
# Reject URLs that point to private / local addresses (SSRF protection).
# Set to "false" only if you explicitly need to shorten internal URLs.
BLOCK_PRIVATE_TARGETS=true

# Per-IP rate limit for the /api/shorten endpoint.
RATE_LIMIT_MAX=20
RATE_LIMIT_WINDOW_MS=60000

# ── Analytics ─────────────────────────────────────────────────
# Maximum number of raw visit events retained per link (older events
# are aggregated then dropped to bound storage growth). 0 = keep all.
VISIT_EVENT_CAP=5000
